{
    "name": "@navikt/astro-auth",
    "version": "1.0.6",
    "license": "MIT",
    "type": "module",
    "packageManager": "pnpm@10.33.0",
    "description": "Astro middleware for authentication in Nav applications using Nais/Wonderwall.",
    "publishConfig": {
        "access": "public",
        "registry": "https://npm.pkg.github.com/"
    },
    "files": [
        "dist",
        "package.json",
        "README.md"
    ],
    "engines": {
        "node": "^20.19.0 || >= 22.12.0 || 24.x"
    },
    "types": "./dist/index.d.ts",
    "exports": {
        ".": "./dist/index.js"
    },
    "scripts": {
        "build": "tsup",
        "clean": "rimraf dist",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "peerDependencies": {
        "astro": "^7.0.0"
    },
    "dependencies": {
        "@navikt/oasis": "^4.0.0"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "astro": "^7.0.0",
        "rimraf": "^6.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0",
        "vitest": "^4.0.0"
    }
}
